# LocalFlow - Environment Configuration Example

# Server configuration
LOCALFLOW_PORT=3000
NODE_ENV=production

# Database credentials
DB_USER=localflow_user
DB_PASSWORD=localflow_secure_pass
DB_NAME=localflow_db

# External service discovery configuration
# Set to 'true' to allow LocalFlow to scan for other local containers via Docker socket
DISCOVERY_ENABLED=true

# Local AI provider defaults (Ollama)
# By default, use 'host.docker.internal' for Linux or Docker Desktop environments
OLLAMA_BASE_URL=http://host.docker.internal:11434
APPFLOWY_BASE_URL=http://host.docker.internal:8080
NOCODB_BASE_URL=http://host.docker.internal:8080

# Traefik configuration
TRAEFIK_DOMAIN=localflow.local
TRAEFIK_PORT=80

# Ollama GPU Passthrough
OLLAMA_GPU_ENABLED=false

# Optional: LLM provider keys (can also be configured via LocalFlow UI)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Internal networking configuration
REDIS_URL=redis://redis:6379
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}
